# Copy to .env (or export as real environment variables) before running the backend.
# Spring Boot reads these via ${VAR:default} placeholders in application.yml — the
# app runs with sane local defaults even if this file is never created.

# --- Database (matches docker-compose.yml defaults) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=farmconnect
DB_USERNAME=farmconnect
DB_PASSWORD=1234

# --- JWT ---
JWT_SECRET=dev-only-insecure-secret-change-me-farmconnect-ai-please-replace-in-prod-32bytes
JWT_EXPIRATION_MS=86400000
JWT_ONBOARDING_EXPIRATION_MS=900000

# --- Google OAuth2 (leave blank to keep "Continue with Google" disabled) ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:8080/login/oauth2/code/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Cloudinary (leave blank to fall back to local disk image storage) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Google Maps (Geocoding API - leave blank to keep manual lat/lng entry) ---
# Same Google Cloud project as GOOGLE_CLIENT_ID above works fine - just enable
# "Geocoding API" for it at https://console.cloud.google.com/apis/library
GOOGLE_MAPS_API_KEY=

# --- Razorpay (leave blank to keep "Pay Online" disabled at checkout - COD still works) ---
# Test-mode keys at https://dashboard.razorpay.com (Settings -> API Keys -> Generate Test Key)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- SMTP email (leave MAIL_USERNAME blank to keep notification emails disabled) ---
# Works with any standard SMTP provider (SendGrid, Mailtrap, Gmail SMTP, etc.)
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM="FarmConnect AI <no-reply@farmconnect.ai>"

# --- Frontend / AI service ---
FRONTEND_BASE_URL=http://localhost:5173
AI_SERVICE_BASE_URL=http://localhost:8000
